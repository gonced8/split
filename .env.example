# Production: Cloudflare Worker proxy (key stays server-side)
VITE_PROXY_URL=https://split-proxy.YOUR_SUBDOMAIN.workers.dev

# Local dev only: call Gemini directly (optional). Restrict this key to http://localhost:* in Google Cloud.
# If set, the app uses it instead of VITE_PROXY_URL so you don't need to allow localhost on the Worker.
# VITE_GEMINI_API_KEY=your_key_here
